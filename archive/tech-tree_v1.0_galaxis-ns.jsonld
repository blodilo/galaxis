      "node_type": "galaxis:node-type/propulsion",
      "tier": 2,
      "research_cost": { "credits": 3000, "resources": { "helium-3": 150, "platinum": 30 } },
      "research_duration_ticks": 50,
      "tags": ["propulsion", "ftl", "tier-2"],
      "unlocks": []
    },
    {
      "@id": "galaxis:tech/ftl-warp-efficiency-2",
      "@type": "galaxis:Node",
      "label": "FTL-Effizienz II",
