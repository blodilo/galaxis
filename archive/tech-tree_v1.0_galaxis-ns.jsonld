      "node_type": "galaxis:node-type/propulsion",
      "tier": 1,
      "research_cost": { "credits": 2000, "resources": { "deuterium": 200, "helium-3": 50 } },
      "research_duration_ticks": 40,
      "tags": ["propulsion", "ftl", "tier-1"],
      "unlocks": ["ftl-core-component"]
    },
