{
  "@context": {
    "galaxis": "https://galaxis-game/ontology#",
    "schema": "https://schema.org/",
    "name": "schema:name",
    "description": "schema:description"
  },
  "@type": "galaxis:Project",
  "@id": "galaxis:project/tech-tree",
  "name": "Galaxis – Technologiebaum",
  "description": "Forschungs- und Technologiebaum für das Strategiespiel Galaxis. Nodes = Technologien, Edges = Forschungsvoraussetzungen.",

  "nodeTypes": [
    {
      "@id": "galaxis:node-type/sensors",
      "@type": "galaxis:NodeType",
      "name": "Sensoren",
      "description": "Optische und FTL-Sensortechnologien, Aufklärung",
      "icon_path": "library:tabler/eye",
      "default_style": {
        "size": 60,
        "background_color": "#dbeafe",
        "border_color": "#3b82f6",
        "font_size": 11
      }
    },
    {
      "@id": "galaxis:node-type/propulsion",
      "@type": "galaxis:NodeType",
      "name": "Antrieb",
      "description": "Sublicht- und FTL-Antriebstechnologien",
      "icon_path": "library:tabler/rocket",
      "default_style": {
        "size": 60,
        "background_color": "#fef9c3",
        "border_color": "#ca8a04",
        "font_size": 11
      }
    },
    {
      "@id": "galaxis:node-type/ftl-modification",
      "@type": "galaxis:NodeType",
      "name": "FTL-Modifikation",
      "description": "Technologien zur Manipulation des FTLW-Skalarfelds",
      "icon_path": "library:tabler/topology-star",
      "default_style": {
        "size": 60,
        "background_color": "#f3e8ff",
        "border_color": "#9333ea",
        "font_size": 11
      }
    },
    {
      "@id": "galaxis:node-type/weapons",
      "@type": "galaxis:NodeType",
      "name": "Waffensysteme",
      "description": "Kinetische, Energie- und Lenkwaffensysteme",
      "icon_path": "library:tabler/crosshair",
      "default_style": {
        "size": 60,
        "background_color": "#fee2e2",
        "border_color": "#dc2626",
        "font_size": 11
      }
    },
    {
      "@id": "galaxis:node-type/defense",
      "@type": "galaxis:NodeType",
      "name": "Verteidigung",
      "description": "Panzerung, Schilde, Gegenmaßnahmen",
      "icon_path": "library:tabler/shield",
      "default_style": {
        "size": 60,
        "background_color": "#dcfce7",
        "border_color": "#16a34a",
        "font_size": 11
      }
    },
    {
      "@id": "galaxis:node-type/economy",
      "@type": "galaxis:NodeType",
      "name": "Wirtschaft & Logistik",
      "description": "Abbau, Produktion, Lieferketten, Handel",
      "icon_path": "library:tabler/building-factory",
      "default_style": {
        "size": 60,
        "background_color": "#fff7ed",
        "border_color": "#ea580c",
        "font_size": 11
      }
    },
    {
      "@id": "galaxis:node-type/planetary",
      "@type": "galaxis:NodeType",
      "name": "Planetare Entwicklung",
      "description": "Besiedlung, Habitate, Terraforming, Bevölkerung",
      "icon_path": "library:tabler/planet",
      "default_style": {
        "size": 60,
        "background_color": "#f0fdf4",
        "border_color": "#22c55e",
        "font_size": 11
      }
    },
    {
      "@id": "galaxis:node-type/military-infrastructure",
      "@type": "galaxis:NodeType",
      "name": "Militärinfrastruktur",
      "description": "Werften, Befestigungen, Kommandosysteme",
      "icon_path": "library:tabler/castle",
      "default_style": {
        "size": 60,
        "background_color": "#f1f5f9",
        "border_color": "#475569",
        "font_size": 11
      }
    }
  ],

  "relationTypes": [
    {
      "@id": "galaxis:relation-type/requires",
      "@type": "galaxis:RelationType",
      "name": "requires",
      "display_label": "erfordert",
      "description": "Diese Technologie kann erst erforscht werden, wenn die Vorgänger-Technologie abgeschlossen ist.",
      "style": {
        "line_style": "solid",
        "line_color": "#6b7280",
        "width": 1.5,
        "target_arrow_shape": "triangle",
        "target_arrow_color": "#6b7280",
        "curve_style": "bezier"
      }
    },
    {
      "@id": "galaxis:relation-type/enables",
      "@type": "galaxis:RelationType",
      "name": "enables",
      "display_label": "ermöglicht",
      "description": "Diese Technologie schaltet ein Gebäude, eine Schiffskomponente oder eine Spielmechanik frei.",
      "style": {
        "line_style": "dashed",
        "line_color": "#3b82f6",
        "width": 1.5,
        "target_arrow_shape": "vee",
        "target_arrow_color": "#3b82f6",
        "curve_style": "bezier"
      }
    },
    {
      "@id": "galaxis:relation-type/synergy",
      "@type": "galaxis:RelationType",
      "name": "synergy",
      "display_label": "Synergie",
      "description": "Zwei Technologien zusammen ergeben einen Bonus über die Summe ihrer Einzelboni hinaus.",
      "style": {
        "line_style": "dotted",
        "line_color": "#f59e0b",
        "width": 1.5,
        "target_arrow_shape": "none",
        "target_arrow_color": "#f59e0b",
        "curve_style": "unbundled-bezier"
      }
    }
  ],

  "nodes": [

    {
      "@id": "galaxis:tech/basic-optics",
      "@type": "galaxis:Node",
      "label": "Basisoptik",
      "description": "Grundlegende Teleskoptechnologie. Ermöglicht den Bau von Scout-Arrays auf Schiffen und kleinen Außenposten.",
      "node_type": "galaxis:node-type/sensors",
      "tier": 1,
      "research_cost": { "credits": 500, "resources": {} },
      "research_duration_ticks": 10,
      "tags": ["sensors", "tier-1"],
      "unlocks": ["ship-scout-array", "outpost-sensor"]
    },
    {
      "@id": "galaxis:tech/advanced-optics",
      "@type": "galaxis:Node",
      "label": "Hochleistungsoptik",
      "description": "Vergrößerte Apertur, verbesserte Spiegeltechnologie. Ermöglicht planetare Observatorien (SR bis 177 m²).",
      "node_type": "galaxis:node-type/sensors",
      "tier": 2,
      "research_cost": { "credits": 2000, "resources": { "titanium": 50 } },
      "research_duration_ticks": 30,
      "tags": ["sensors", "tier-2"],
      "unlocks": ["planetary-observatory"]
    },
    {
      "@id": "galaxis:tech/sensor-array-networking",
      "@type": "galaxis:Node",
      "label": "Sensornetzwerk-Protokoll",
      "description": "Ermöglicht die additive Kombination stationärer Sensoren zu einem Interferometer-Netzwerk. Netzwerk-SR = Summe aller verbundenen Stationen.",
      "node_type": "galaxis:node-type/sensors",
      "tier": 2,
      "research_cost": { "credits": 1500, "resources": { "neodymium": 20 } },
      "research_duration_ticks": 25,
      "tags": ["sensors", "tier-2", "network"],
      "unlocks": ["sensor-network-link"]
    },
    {
      "@id": "galaxis:tech/deep-space-array",
      "@type": "galaxis:Node",
      "label": "Deep-Space-Array",
      "description": "Massive Megastruktur-Sensoren auf Planetenoberflächen (SR bis 707 m²+). Erfordert ausgebaute Infrastruktur.",
      "node_type": "galaxis:node-type/sensors",
      "tier": 3,
      "research_cost": { "credits": 8000, "resources": { "titanium": 200, "neodymium": 100 } },
      "research_duration_ticks": 80,
      "tags": ["sensors", "tier-3"],
      "unlocks": ["deep-space-array-structure"]
    },
    {
      "@id": "galaxis:tech/ftl-sensor-theory",
      "@type": "galaxis:Node",
      "label": "FTL-Sensortheorie",
      "description": "Grundlagenforschung zur Messung von FTLW-Skalarfeld-Gradienten. Voraussetzung für alle FTL-Sensoren.",
      "node_type": "galaxis:node-type/sensors",
      "tier": 2,
      "research_cost": { "credits": 3000, "resources": { "yttrium": 30 } },
      "research_duration_ticks": 40,
      "tags": ["sensors", "ftl", "tier-2"],
      "unlocks": ["ftl-sensor-station"]
    },
    {
      "@id": "galaxis:tech/ftl-sensor-advanced",
      "@type": "galaxis:Node",
      "label": "FTL-Warp-Signatur-Analyse",
      "description": "Erkennt die kurzzeitige FTL-Signatur von Schiffen beim Warp-Eintritt. Ermöglicht frühzeitige Warnung vor feindlichen Flottenbewegungen.",
      "node_type": "galaxis:node-type/sensors",
      "tier": 3,
      "research_cost": { "credits": 6000, "resources": { "yttrium": 80, "californium-252": 5 } },
      "research_duration_ticks": 60,
      "tags": ["sensors", "ftl", "tier-3"],
      "unlocks": ["ftl-warp-detector"]
    },

    {
      "@id": "galaxis:tech/fusion-drive",
      "@type": "galaxis:Node",
      "label": "Fusionsantrieb",
      "description": "Primärer Sublicht-Antrieb für alle Schiffe. Treibstoff: Deuterium. Baseline für alle weiteren Antriebstechnologien.",
      "node_type": "galaxis:node-type/propulsion",
      "tier": 1,
      "research_cost": { "credits": 800, "resources": { "deuterium": 100 } },
      "research_duration_ticks": 15,
      "tags": ["propulsion", "tier-1"],
      "unlocks": ["fusion-drive-component"]
    },
    {
      "@id": "galaxis:tech/ftl-warp-basic",
