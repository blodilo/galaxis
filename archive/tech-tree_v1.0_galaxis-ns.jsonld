      "node_type": "galaxis:node-type/propulsion",
      "tier": 3,
      "research_cost": { "credits": 8000, "resources": { "helium-3": 400, "platinum": 100 } },
      "research_duration_ticks": 80,
      "tags": ["propulsion", "ftl", "tier-3"],
      "unlocks": []
    },

