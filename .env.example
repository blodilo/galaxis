# Galaxis – Entwicklungs-Credentials
# Kopieren nach .env und Werte anpassen.
# .env wird NICHT ins Repository eingecheckt.

POSTGRES_USER=galaxis
POSTGRES_PASSWORD=galaxis_dev
POSTGRES_DB=galaxis

REDIS_PASSWORD=

# Für den Server (DSN-Format):
DATABASE_URL=postgres://galaxis:galaxis_dev@localhost:5432/galaxis?sslmode=disable
REDIS_URL=redis://localhost:6379
