{
  "@context": {
    "kg": "https://kg-app/ontology#",
    "schema": "https://schema.org/",
    "name": "schema:name",
    "description": "schema:description"
  },
  "@type": "kg:Project",
  "@id": "kg:project/galaxis-tech-tree",
  "name": "Galaxis – Technologiebaum",
  "description": "Forschungs- und Technologiebaum für das Strategiespiel Galaxis. Nodes = Technologien, Edges = Forschungsvoraussetzungen. Jede Technologie erzeugt nach Abschluss einen Bauplan (Konstruktionsunterlagen).",
  "nodeTypes": [
    {
      "@id": "kg:node-type/tech-sensors",
      "@type": "kg:NodeType",
      "name": "Sensoren",
      "description": "Optische und FTL-Sensortechnologien, Aufklärung",
      "icon_path": "library:tabler/eye",
      "default_style": {
        "size": 60,
        "background_color": "#dbeafe",
        "border_color": "#3b82f6",
        "font_size": 11
      }
    },
    {
      "@id": "kg:node-type/tech-propulsion",
      "@type": "kg:NodeType",
      "name": "Antrieb",
      "description": "Sublicht- und FTL-Antriebstechnologien",
      "icon_path": "library:tabler/rocket",
      "default_style": {
        "size": 60,
        "background_color": "#fef9c3",
        "border_color": "#ca8a04",
        "font_size": 11
      }
    },
    {
      "@id": "kg:node-type/tech-ftl-modification",
      "@type": "kg:NodeType",
      "name": "FTL-Modifikation",
      "description": "Technologien zur Manipulation des FTLW-Skalarfelds",
      "icon_path": "library:tabler/topology-star",
      "default_style": {
        "size": 60,
        "background_color": "#f3e8ff",
        "border_color": "#9333ea",
        "font_size": 11
      }
    },
    {
      "@id": "kg:node-type/tech-weapons",
      "@type": "kg:NodeType",
      "name": "Waffensysteme",
      "description": "Kinetische, Energie- und Lenkwaffensysteme",
      "icon_path": "library:tabler/crosshair",
      "default_style": {
        "size": 60,
        "background_color": "#fee2e2",
        "border_color": "#dc2626",
        "font_size": 11
      }
    },
    {
      "@id": "kg:node-type/tech-defense",
      "@type": "kg:NodeType",
      "name": "Verteidigung",
      "description": "Panzerung, Gegenmaßnahmen, thermisches Management",
      "icon_path": "library:tabler/shield",
      "default_style": {
        "size": 60,
        "background_color": "#dcfce7",
        "border_color": "#16a34a",
        "font_size": 11
      }
    },
    {
      "@id": "kg:node-type/tech-economy",
      "@type": "kg:NodeType",
      "name": "Wirtschaft & Logistik",
      "description": "Abbau, Produktion, Lieferketten, Handel",
      "icon_path": "library:tabler/building-factory",
      "default_style": {
        "size": 60,
        "background_color": "#fff7ed",
        "border_color": "#ea580c",
        "font_size": 11
      }
    },
    {
      "@id": "kg:node-type/tech-planetary",
      "@type": "kg:NodeType",
      "name": "Planetare Entwicklung",
      "description": "Besiedlung, Habitate, Terraforming, Bevölkerung",
      "icon_path": "library:tabler/planet",
      "default_style": {
        "size": 60,
        "background_color": "#f0fdf4",
        "border_color": "#22c55e",
        "font_size": 11
      }
    },
    {
      "@id": "kg:node-type/tech-military",
      "@type": "kg:NodeType",
      "name": "Militärinfrastruktur",
      "description": "Werften, Befestigungen, Kommandosysteme",
      "icon_path": "library:tabler/castle",
      "default_style": {
        "size": 60,
        "background_color": "#f1f5f9",
        "border_color": "#475569",
        "font_size": 11
      }
    }
  ],
  "relationTypes": [
    {
      "@id": "kg:relation-type/requires",
      "@type": "kg:RelationType",
      "name": "requires",
      "display_label": "erfordert",
      "description": "Diese Technologie kann erst erforscht werden, wenn die Vorgänger-Technologie abgeschlossen ist.",
      "style": {
        "line_style": "solid",
        "line_color": "#6b7280",
        "width": 1.5,
        "target_arrow_shape": "triangle",
        "target_arrow_color": "#6b7280",
        "curve_style": "bezier"
      }
    },
    {
      "@id": "kg:relation-type/enables",
      "@type": "kg:RelationType",
      "name": "enables",
      "display_label": "ermöglicht",
      "description": "Diese Technologie schaltet ein Gebäude, eine Schiffskomponente oder eine Spielmechanik frei.",
      "style": {
        "line_style": "dashed",
        "line_color": "#3b82f6",
        "width": 1.5,
        "target_arrow_shape": "vee",
        "target_arrow_color": "#3b82f6",
        "curve_style": "bezier"
      }
    },
    {
      "@id": "kg:relation-type/synergy",
      "@type": "kg:RelationType",
      "name": "synergy",
      "display_label": "Synergie",
      "description": "Zwei Technologien zusammen ergeben einen Bonus über die Summe ihrer Einzelboni hinaus.",
      "style": {
        "line_style": "dotted",
        "line_color": "#f59e0b",
        "width": 1.5,
        "target_arrow_shape": "none",
        "target_arrow_color": "#f59e0b",
        "curve_style": "unbundled-bezier"
      }
    }
  ],
